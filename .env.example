# Required for the "Share on LinkedIn" button to work.
# Copy to .env.local for local dev, and set them on Vercel for production.

# From the LinkedIn Developer Portal (https://www.linkedin.com/developers/apps)
# Your app needs the "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect" products.
# Scopes requested at runtime: openid profile email w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Must be registered in the LinkedIn app's "Authorized redirect URLs" config.
# Production: https://vibing-with-irdi.vercel.app/api/linkedin/callback
# Local dev:  http://localhost:4321/api/linkedin/callback
LINKEDIN_REDIRECT_URI=https://vibing-with-irdi.vercel.app/api/linkedin/callback

# Random string used to HMAC-sign the OAuth state cookie. Generate with
# `openssl rand -hex 32`. Rotate freely.
SESSION_SECRET=

# Anthropic API key. Used to generate the viral LinkedIn caption from the
# post markdown via claude-sonnet-4-6.
ANTHROPIC_API_KEY=

# Optional. Defaults to https://vibing-with-irdi.vercel.app
SITE=

# Admin gate. Anyone who hits /api/admin?key=<ADMIN_SECRET> gets a 30-day
# signed admin cookie. The "share on linkedin" button auto-posts (full OAuth
# + AI caption) only for admins; non-admins are redirected to LinkedIn's
# standard share dialog. Generate with `openssl rand -hex 24`.
ADMIN_SECRET=

# Upstash Redis credentials (free tier). Powers the heart + view counters on
# each post. Sign up at https://upstash.com, create a Redis database, then
# copy the REST URL + REST TOKEN from the database dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
