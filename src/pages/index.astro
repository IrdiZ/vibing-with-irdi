---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---

<Layout
  title="vibing with irdi"
  description="engineering, mostly. vibes always. notes on shipping stuff and the occasional W."
>
  <section class="hero">
    <h1>
      vibing<br />
      with <span class="accent">irdi</span>
    </h1>
    <p>engineering, mostly. vibes, always. notes from shipping stuff that ends up working.</p>
  </section>

  <aside class="about-card">
    <span class="about-tag">author</span>
    <img src="/me.jpg" alt="irdi" class="about-photo" width="96" height="96" />
    <div class="about-content">
      <strong>i'm irdi.</strong>
      <p>most of this blog is vibe-coded with claude. that's the whole point. each post is a notebook of what AI actually does when you hand it a real engineering problem, where it gets clever, where you have to steer it back, and what's left after the dust settles.</p>
      <p>it's an experiment, not a portfolio. read it as a record of what AI-assisted engineering looks like when you actually care about the craft. grain of salt encouraged.</p>
    </div>
  </aside>

  <section class="posts">
    <h2>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</h2>
    {
      posts.map((post) => (
        <a class="post-card" href={`/posts/${post.id}`}>
          <div class="meta">
            <span class="dot"></span>
            <span>{fmt(post.data.date)}</span>
          </div>
          <h3>{post.data.title}</h3>
          <p class="excerpt">{post.data.excerpt}</p>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}
        </a>
      ))
    }
  </section>
</Layout>
